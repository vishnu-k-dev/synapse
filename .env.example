# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=synapse
POSTGRES_USER=synapse
POSTGRES_PASSWORD=changeme

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_SPECS=synapse-specs
MINIO_BUCKET_ARTIFACTS=synapse-artifacts
MINIO_SECURE=false

# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_PRIMARY_MODEL=gpt-4o-mini
ANTHROPIC_FALLBACK_MODEL=claude-haiku-4-5-20251001

# ── Security ──────────────────────────────────────────────────────────────────
# 32 random bytes base64-encoded — generate with: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
CREDENTIAL_ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTES

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO
API_KEY=dev-api-key-replace-in-prod

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
