# Copy to `.env` and fill in. Loaded automatically by run_experiment.py.

# Required for both offline and live runs (the agent is GPT-4o via OpenAI):
OPENAI_API_KEY=sk-...

# Live mode only — where the SYNAPSE backend is reachable:
SYNAPSE_API_URL=http://localhost:8000
SYNAPSE_API_KEY=dev-api-key-replace-in-prod

# Optional overrides:
# EVAL_AGENT_MODEL=gpt-4o-2024-11-20
# EVAL_REPEATS=3
